# Sage Accounting API — server-side only (never commit real values)
# Copy to Vercel Production env vars. Do not commit .env or .env.local.

APP_BASE_URL=
SAGE_CLIENT_ID=
SAGE_CLIENT_SECRET=
SAGE_REDIRECT_URI=
SAGE_API_BASE_URL=https://api.accounting.sage.com/v3.1
TOKEN_ENCRYPTION_KEY=

# Gmail API — server-side only. Use the uploaded Google "web" OAuth client.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://www.getsynpath-ai.com/api/gmail/oauth/callback
GOOGLE_GMAIL_SCOPES=https://www.googleapis.com/auth/gmail.readonly https://www.googleapis.com/auth/gmail.send
GOOGLE_TOKEN_ENCRYPTION_KEY=

# Document AI (shared processor on project synpath / 642075982640)
GCLOUD_DOCUMENT_AI_PROJECT_ID=642075982640
GCLOUD_DOCUMENT_AI_LOCATION=eu
GCLOUD_DOCUMENT_AI_PROCESSOR_NAME=invoice_parser_1
GCLOUD_DOCUMENT_AI_PROCESSOR_ID=1957e3e895988b13
# Vercel: base64 of SA JSON (do not use file path on serverless)
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=

# Acrylic LLM enrich + invoice structure (required for parity with ai_erp)
# ai_erp default backend is auto: PDF text+LLM (best qty/unit price), not Document AI line items.
OPENAI_API_KEY=
GHOST_PO_PARSE_MODEL=gpt-4o-mini
# auto | text | documentai_ocr | documentai
GHOST_PO_PARSE_BACKEND=auto

# Demo Run baseline storage (Vercel KV / Upstash Redis REST). Recommended for production.
# When unset, encrypted HttpOnly cookie mirroring is used as a temporary fallback.
KV_REST_API_URL=
KV_REST_API_TOKEN=
# Set to 1 only for local/unit tests.
DEMO_RUN_MEMORY_STORE=
